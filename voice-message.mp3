<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 400" role="img" aria-labelledby="title desc">
  <title id="title">照片占位图</title>
  <desc id="desc">粉色渐变背景上的信封和爱心</desc>
  <defs>
    <linearGradient id="bg" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="#ffe8f5"/>
      <stop offset="1" stop-color="#ffc2e3"/>
    </linearGradient>
    <filter id="soft" x="-20%" y="-20%" width="140%" height="140%">
      <feDropShadow dx="0" dy="8" stdDeviation="8" flood-color="#b62b79" flood-opacity=".22"/>
    </filter>
  </defs>
  <rect width="400" height="400" rx="72" fill="url(#bg)"/>
  <circle cx="72" cy="78" r="18" fill="#fff" opacity=".55"/>
  <circle cx="338" cy="310" r="28" fill="#fff" opacity=".42"/>
  <g filter="url(#soft)">
    <rect x="74" y="124" width="252" height="174" rx="30" fill="#fff" stroke="#272128" stroke-width="11"/>
    <path d="M87 145l113 93 113-93" fill="#ffd8ec" stroke="#272128" stroke-linecap="round" stroke-linejoin="round" stroke-width="11"/>
    <path d="M91 280l76-69m142 69l-76-69" fill="none" stroke="#272128" stroke-linecap="round" stroke-width="10"/>
  </g>
  <path d="M200 105c-24-31-74-5-51 31 14 22 51 44 51 44s37-22 51-44c23-36-27-62-51-31z" fill="#f54fb0" stroke="#272128" stroke-linejoin="round" stroke-width="9"/>
</svg>
